# === Supabase (tùy chọn) — để TRỐNG thì app chạy chế độ localStorage ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# === AI chấm Writing (tùy chọn) — cần để dùng nút "Chấm bài bằng AI" ===
# Lấy key tại https://console.anthropic.com  (GIỮ KÍN — không có tiền tố NEXT_PUBLIC)
ANTHROPIC_API_KEY=
# Model dùng để chấm (tùy chọn). Mặc định Sonnet 4.6.
ANTHROPIC_MODEL=claude-sonnet-4-6
